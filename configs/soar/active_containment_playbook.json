{
  "playbook_name": "SOAR-Incident-Response-Isolation",
  "trigger_event": "Wazuh-Alert-Level-12-Or-Higher",
  "workflow_steps": [
    {
      "step": 1,
      "action": "Network Isolation",
      "target": "Infected-Host-IP",
      "command": "EDR_Agent_Isolate_Host()",
      "status": "Automated"
    },
    {
      "step": 2,
      "action": "Identity Containment",
      "target": "Compromised-User-ID",
      "command": "IAM_Revoke_Active_Sessions_And_Force_MFA()",
      "status": "Automated"
    },
    {
      "step": 3,
      "action": "Forensic Preservation",
      "target": "Memory-Dump",
      "command": "Snapshot_Host_Memory_To_S3_Bucket()",
      "status": "Automated"
    },
    {
      "step": 4,
      "action": "Notification",
      "target": "SOC-Team",
      "command": "Create_High_Priority_Jira_Ticket()",
      "status": "Automated"
    }
  ]
}